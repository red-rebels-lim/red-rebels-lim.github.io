{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rrcalendar",
  "compatibility_date": "2026-04-12",
  "main": "src/_worker.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
